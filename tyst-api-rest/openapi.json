    "/se/{algorithm}/keygen": {
      "post": {
        "tags": [
          "se_resources"
        ],
        "summary": "Start key pair generation.",
        "description": "Start generation of a suitable asymmetric key pair for the signature algorithm.",
        "operationId": "se_keygen",
        "parameters": [
          {
            "name": "algorithm",
            "in": "path",
            "description": "The signature algorithm.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "strength",
            "in": "query",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "strength": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "format": "int32",
                  "minimum": 0
                }
              }
            }
          }
        ],
        "responses": {
          "303": {
            "description": "Key generation has started. Redirecting to result resource."
          },
          "404": {
            "description": "Failed to start"
          },
          "429": {
            "description": "Too many requests are already in progress"
          }
        }
      }
    },
    "/se/{algorithm}/keygen/{generation_request_id}": {
      "get": {
        "tags": [
          "se_resources"
        ],
        "summary": "Get generated key pair.",
        "description": "Get generated suitable asymmetric key pair for the signature algorithm.",
        "operationId": "se_keygen_result",
        "parameters": [
          {
            "name": "algorithm",
            "in": "path",
            "description": "The signature algorithm.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "generation_request_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "private_key",
                    "public_key_b64"
                  ],
                  "properties": {
                    "private_key": {
