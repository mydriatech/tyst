                      },
                      "object_reference": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Identifier used by provider to locate the correct object."
                      }
                    }
                  },
                  "message_b64": {
                    "type": "array",
                    "items": {
                      "type": "integer",
                      "format": "int32",
                      "minimum": 0
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "mac_b64"
