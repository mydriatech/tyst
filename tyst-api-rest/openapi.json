            "name": "algorithm",
            "in": "path",
            "description": "The MAC algorithm.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "key",
                  "message_b64"
                ],
                "properties": {
                  "key": {
                    "type": "object",
                    "required": [
                      "key_material_b64"
                    ],
                    "properties": {
                      "confinement_id": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Identifier used by provider to locate the correct confinement."
                      },
                      "confinement_type": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Type of confinement. E.g. \"soft\"."
                      },
                      "key_material_b64": {
                        "type": "array",
                        "items": {
                          "type": "integer",
                          "format": "int32",
                          "minimum": 0
                        },
